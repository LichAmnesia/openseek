{
  "name": "openseek",
  "version": "0.0.3",
  "description": "Open-source TUI coding agent — TypeScript / Bun monorepo with multi-provider routing, MCP, LSP, and Plan/Agent/YOLO modes.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LichAmnesia/openseek.git"
  },
  "homepage": "https://openseek.dev/",
  "bugs": {
    "url": "https://github.com/LichAmnesia/openseek/issues"
  },
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "README.md",
    "README-zh.md"
  ],
  "scripts": {
    "dev": "bun run packages/cli/src/index.ts",
    "build": "bun run scripts/build.ts",
    "init": "bash scripts/init.sh",
    "lint": "bash scripts/lint.sh",
    "typecheck": "bash scripts/typecheck.sh",
    "test": "bash scripts/test.sh",
    "verify": "bash scripts/verify.sh",
    "prepublishOnly": "bun run build"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "openseek": "bin/openseek"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.100",
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/azure": "^3.0.61",
    "@ai-sdk/google": "^3.0.67",
    "@ai-sdk/google-vertex": "^4.0.120",
    "@ai-sdk/openai-compatible": "^2.0.46",
    "@iarna/toml": "^2.2.5",
    "@opentui/core": "^0.2.2",
    "@opentui/solid": "^0.2.2",
    "ai": "^6.0.175",
    "hono": "^4.12.16",
    "solid-js": "^1.9.12",
    "web-tree-sitter": "0.25.10",
    "zod": "^4.4.3"
  }
}
