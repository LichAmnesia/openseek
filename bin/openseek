#!/bin/sh
# Root launcher for `openseek`.
#
# Why a sh wrapper instead of `#!/usr/bin/env bun`:
# we must invoke bun with `--conditions=browser` so solid-js resolves to its
# universal build (`./dist/solid.js`) instead of the SSR build
# (`./dist/server.js` — bun's default `node` exports condition).
# The SSR build's createMemo is a stub and crashes inside @opentui/solid.
# solid-js is `external` in the published bundle, so this resolution happens
# at runtime on the user's machine and the build-time plugin can't help.

set -e
HERE=$(cd "$(dirname "$0")" && pwd)
DIST_ENTRY="$HERE/../dist/index.js"
SRC_ENTRY="$HERE/../packages/cli/src/index.ts"

if [ -f "$DIST_ENTRY" ]; then
  ENTRY="$DIST_ENTRY"
else
  ENTRY="$SRC_ENTRY"
fi

exec bun --conditions=browser "$ENTRY" "$@"
